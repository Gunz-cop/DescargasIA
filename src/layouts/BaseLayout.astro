---
// src/layouts/BaseLayout.astro
import '../styles/global.css';
import { useTranslations, languages } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogType?: string;
  ogImage?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  lang?: 'es' | 'sv' | 'it';
  alternates?: Array<{ lang: string; url: string }>;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogType = 'website',
  ogImage = 'https://fuenteia.com/default-share.jpg',
  jsonLd,
  lang = 'es',
  alternates = []
} = Astro.props;

const t = useTranslations(lang);

const navNames = {
  es: {
    asistentes: 'Asistentes',
    programacion: 'Programación',
    modelos: 'Modelos Locales',
    imagen: 'Imagen',
    video: 'Video'
  },
  sv: {
    asistentes: 'Assistenter',
    programacion: 'Programmering',
    modelos: 'Lokala Modeller',
    imagen: 'Bild',
    video: 'Video'
  },
  it: {
    asistentes: 'Assistenti',
    programacion: 'Programmazione',
    modelos: 'Modelli Locali',
    imagen: 'Immagini',
    video: 'Video'
  }
};

const nav = navNames[lang];
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Básico -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Alternates Hreflang para Multilenguaje -->
    {alternates.map(({ lang: altLang, url }) => (
      <link rel="alternate" hreflang={altLang === 'es' ? 'es-ES' : altLang === 'sv' ? 'sv-SE' : 'it-IT'} href={url} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${Astro.url.origin}/es`} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Open Graph (Facebook / WhatsApp / etc.) -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="FuenteAI" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;700&family=Outfit:wght@600;700;800;900&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Datos Estructurados Schema.org -->
    {jsonLd && (Array.isArray(jsonLd) ? jsonLd : [jsonLd]).map(schema => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col justify-between">
    <!-- Fondo editorial sobrio -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none -z-20 bg-brand-bg">
      <div class="absolute inset-0 bg-[radial-gradient(rgba(16,185,129,0.055)_1px,transparent_1px)] bg-[size:30px_30px]"></div>
      <div class="absolute inset-0 bg-[linear-gradient(to_bottom,transparent,var(--brand-bg))]"></div>
    </div>

    <!-- HEADER / NAVIGATION -->
    <header class="sticky top-0 z-40 border-b border-brand-card-border bg-brand-bg/92 backdrop-blur-md transition-all">
      <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
        <a href={`/${lang}`} class="flex items-center gap-2 group" aria-label={`Ir al inicio de FuenteAI - ${lang}`}>
          <span class="font-mono text-sm font-bold text-brand-primary border border-brand-primary/30 bg-brand-primary/10 rounded px-2 py-1 group-hover:bg-brand-primary/15 transition-colors" aria-hidden="true">&gt;_</span>
          <span class="text-lg font-black tracking-tight text-brand-text group-hover:text-brand-primary transition-colors">
            FuenteAI
          </span>
        </a>

        <nav class="hidden md:flex items-center gap-4 text-xs font-semibold text-brand-text-muted lg:gap-6 lg:text-sm" aria-label="Navegación principal">
          <a href={`/${lang}/categoria/asistentes-ia`} class="hover:text-brand-text transition-colors">{nav.asistentes}</a>
          <a href={`/${lang}/categoria/programacion`} class="hover:text-brand-text transition-colors">{nav.programacion}</a>
          <a href={`/${lang}/categoria/modelos-locales`} class="hover:text-brand-text transition-colors">{nav.modelos}</a>
          <a href={`/${lang}/categoria/generacion-imagenes`} class="hover:text-brand-text transition-colors">{nav.imagen}</a>
          <a href={`/${lang}/categoria/video-ia`} class="hover:text-brand-text transition-colors">{nav.video}</a>
        </nav>

        <div class="flex items-center gap-3">
          <!-- Selector de Idioma -->
          <div class="relative inline-block text-left">
            <select
              id="lang-selector"
              class="min-h-11 px-2.5 rounded-lg border border-brand-card-border bg-brand-card-bg text-[11px] font-bold text-brand-text-muted hover:text-brand-text hover:border-brand-primary/35 transition-all focus:outline-none cursor-pointer"
              aria-label="Cambiar idioma / Byt språk / Cambia lingua"
            >
              {Object.entries(languages).map(([key, name]) => (
                <option value={key} selected={key === lang}>
                  {name}
                </option>
              ))}
            </select>
          </div>

          <!-- Toggle de modo claro/oscuro simple -->
          <button 
            type="button" 
            id="theme-toggle" 
            class="min-h-11 px-3 rounded-lg border border-brand-card-border bg-brand-card-bg text-[11px] font-bold text-brand-text-muted hover:text-brand-text hover:border-brand-primary/35 transition-all active:scale-[0.98] cursor-pointer"
            aria-label="Alternar tema claro/oscuro"
          >
            <span id="theme-toggle-icon">{lang === 'sv' ? 'Mörkt' : lang === 'it' ? 'Scuro' : 'Oscuro'}</span>
          </button>
        </div>
      </div>
    </header>

    <!-- MAIN CONTENT -->
    <main class="flex-grow max-w-7xl w-full mx-auto px-4 py-8 relative">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="border-t border-brand-card-border bg-brand-card-bg/40 mt-12 py-10 transition-colors">
      <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex flex-col gap-2 text-center md:text-left">
          <span class="text-base font-black tracking-tight text-brand-text">
            FuenteAI
          </span>
          <p class="text-xs text-brand-text-muted max-w-md leading-relaxed">
            {t('footer.disclaimer')}
          </p>
        </div>

        <div class="flex flex-wrap justify-center gap-6 text-xs font-medium text-brand-text-muted">
          <a href={`/${lang}/categoria/asistentes-ia`} class="hover:text-brand-text transition-colors">{nav.asistentes}</a>
          <a href={`/${lang}/categoria/programacion`} class="hover:text-brand-text transition-colors">{nav.programacion}</a>
          <a href={`/${lang}/categoria/modelos-locales`} class="hover:text-brand-text transition-colors">{nav.modelos}</a>
          <a href={`/${lang}/aviso-legal`} class="hover:text-brand-text transition-colors">{t('footer.legal')}</a>
          <a href={`/${lang}/privacidad`} class="hover:text-brand-text transition-colors">{t('footer.privacy')}</a>
        </div>
      </div>
      <div class="max-w-7xl mx-auto px-4 border-t border-brand-card-border/40 mt-8 pt-6 text-center text-[10px] text-brand-text-muted/60">
        © {new Date().getFullYear()} FuenteAI. {lang === 'sv' ? 'Alla rättigheter förbehållna.' : lang === 'it' ? 'Tutti i diritti riservati.' : 'Todos los derechos reservados.'} {lang === 'sv' ? 'Alla varumärken och logotyper är tillhörande sina respektive ägare.' : lang === 'it' ? 'Tutti i marchi e i loghi IA appartengono ai rispettivi proprietari.' : 'Todos los nombres de marcas y logos de IA son propiedad de sus respectivos dueños.'}
      </div>
    </footer>

    <!-- Theme & Language Switch Scripts -->
    <script is:inline>
      // Selector de idioma client-side
      const langSelector = document.getElementById('lang-selector');
      if (langSelector) {
        langSelector.addEventListener('change', (e) => {
          const newLang = e.target.value;
          // Reemplazar la primera parte de la ruta del path (/es/ -> /sv/)
          const pathSegments = window.location.pathname.split('/').filter(Boolean);
          if (pathSegments.length > 0 && ['es', 'sv', 'it'].includes(pathSegments[0])) {
            pathSegments[0] = newLang;
            window.location.pathname = '/' + pathSegments.join('/');
          } else {
            window.location.pathname = '/' + newLang;
          }
        });
      }

      // Controlador del tema
      const themeToggle = document.getElementById('theme-toggle');
      const themeIcon = document.getElementById('theme-toggle-icon');
      const isSwedish = document.documentElement.lang === 'sv';
      const isItalian = document.documentElement.lang === 'it';
      
      const getTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return 'dark';
      };

      const setTheme = (theme) => {
        if (theme === 'light') {
          document.documentElement.classList.add('light');
          if (themeIcon) themeIcon.textContent = isSwedish ? 'Ljust' : isItalian ? 'Chiaro' : 'Claro';
        } else {
          document.documentElement.classList.remove('light');
          if (themeIcon) themeIcon.textContent = isSwedish ? 'Mörkt' : isItalian ? 'Scuro' : 'Oscuro';
        }
        localStorage.setItem('theme', theme);
      };

      setTheme(getTheme());

      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          const isLight = document.documentElement.classList.contains('light');
          setTheme(isLight ? 'dark' : 'light');
        });
      }
    </script>
  </body>
</html>
