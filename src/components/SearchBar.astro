---
// src/components/SearchBar.astro
import { getCollection } from 'astro:content';

const categories = await getCollection('categories');

const platforms = [
  { id: 'web', name: 'Web' },
  { id: 'windows', name: 'Windows' },
  { id: 'mac', name: 'macOS' },
  { id: 'linux', name: 'Linux' },
  { id: 'android', name: 'Android' },
  { id: 'ios', name: 'iOS' }
];
---

<div class="w-full mb-8 flex flex-col gap-4" aria-labelledby="buscador-ia-title">
  <div class="rounded-lg border border-brand-card-border bg-brand-card-bg p-3 transition-colors focus-within:border-brand-primary/45">
    <label id="buscador-ia-title" for="search-input" class="mb-2 block text-[11px] font-bold uppercase text-brand-text-muted">
      Buscar herramienta verificada
    </label>
    <div class="flex min-h-11 items-center gap-3 rounded-md border border-brand-card-border bg-brand-bg/35 px-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-brand-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z" />
      </svg>
      <input
        type="search"
        id="search-input"
        placeholder="Buscar ChatGPT, Gemini, Claude, Ollama, Cursor..."
        autocomplete="off"
        class="min-w-0 flex-1 bg-transparent py-2 text-sm text-brand-text placeholder-brand-text-muted/55 focus:outline-none"
      />
      <button id="btn-clear-search" class="hidden inline-flex min-h-9 min-w-9 items-center justify-center rounded-md text-brand-text-muted transition-colors hover:bg-brand-card-bg hover:text-brand-primary cursor-pointer" aria-label="Limpiar búsqueda">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="h-4 w-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <div class="rounded-lg border border-brand-card-border bg-brand-card-bg p-4">
    <div class="grid gap-4">
      <div class="grid gap-2">
        <div class="flex items-center justify-between gap-3">
          <span class="text-[11px] font-bold uppercase text-brand-text-muted">Categoría</span>
          <span class="hidden text-[10px] text-brand-text-muted/70 sm:inline">Filtra por tipo de herramienta</span>
        </div>
        <div class="flex items-center gap-2 overflow-x-auto pb-1 scrollbar-none" id="category-filters-container">
          <button
            data-filter-category="todos"
            class="min-h-10 shrink-0 rounded-md border border-transparent bg-brand-primary px-3 py-2 text-xs font-bold text-white transition-colors cursor-pointer active:scale-[0.98]"
          >
            Todas
          </button>
          {categories.map(cat => (
            <button
              data-filter-category={cat.data.slug}
              class="min-h-10 shrink-0 rounded-md border border-brand-card-border bg-brand-bg/40 px-3 py-2 text-xs font-semibold text-brand-text-muted transition-colors hover:border-brand-primary/30 hover:text-brand-text cursor-pointer active:scale-[0.98]"
            >
              {cat.data.name}
            </button>
          ))}
        </div>
      </div>

      <div class="border-t border-brand-card-border"></div>

      <div class="grid gap-2">
        <div class="flex items-center justify-between gap-3">
          <span class="text-[11px] font-bold uppercase text-brand-text-muted">Plataforma</span>
          <span class="hidden text-[10px] text-brand-text-muted/70 sm:inline">Encuentra lo compatible con tu equipo</span>
        </div>
        <div class="flex items-center gap-2 overflow-x-auto pb-1 scrollbar-none" id="platform-filters-container">
          <button
            data-filter-platform="todos"
            class="min-h-10 shrink-0 rounded-md border border-transparent bg-brand-primary px-3 py-2 text-xs font-bold text-white transition-colors cursor-pointer active:scale-[0.98]"
          >
            Cualquiera
          </button>
          {platforms.map(plat => (
            <button
              data-filter-platform={plat.id}
              class="min-h-10 shrink-0 rounded-md border border-brand-card-border bg-brand-bg/40 px-3 py-2 text-xs font-semibold text-brand-text-muted transition-colors hover:border-brand-primary/30 hover:text-brand-text cursor-pointer active:scale-[0.98]"
            >
              {plat.name}
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>
