---
// src/components/SearchBar.astro
import { getCollection } from 'astro:content';

const categories = await getCollection('categories');

const platforms = [
  { id: 'web', name: '🌐 Web' },
  { id: 'windows', name: '🖥️ Windows' },
  { id: 'mac', name: '🍎 macOS' },
  { id: 'linux', name: '🐧 Linux' },
  { id: 'android', name: '🤖 Android' },
  { id: 'ios', name: '📱 iOS' }
];
---

<div class="w-full mb-8 flex flex-col gap-4" aria-labelledby="buscador-ia-title">
  <!-- Input de Búsqueda Principal -->
  <div class="relative group rounded-2xl bg-brand-card-bg/30 border border-brand-card-border/80 shadow-md focus-within:border-brand-primary/45 focus-within:ring-2 focus-within:ring-brand-primary/10 transition-all duration-300">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" 
      class="absolute left-4 top-1/2 -translate-y-1/2 w-4.5 h-4.5 text-brand-text-muted/60 pointer-events-none group-focus-within:text-brand-primary transition-colors">
      <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
    </svg>
    <input 
      type="search" 
      id="search-input" 
      placeholder="Buscar herramientas de IA por nombre, tags, características..."
      autocomplete="off"
      class="w-full pl-12 pr-10 py-4 bg-transparent text-brand-text placeholder-brand-text-muted/50 text-sm focus:outline-none focus:ring-0 transition-colors"
    />
    <button id="btn-clear-search" class="absolute right-3.5 top-1/2 -translate-y-1/2 text-brand-text-muted hover:text-brand-primary transition-colors cursor-pointer hidden" aria-label="Limpiar búsqueda">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Fila de Filtros -->
  <div class="p-4 rounded-2xl bg-brand-card-bg/30 border border-brand-card-border/80 flex flex-col gap-4 shadow-md backdrop-blur-md transition-all duration-300">
    <!-- Filtros de Categorías -->
    <div class="flex flex-col gap-2">
      <div class="flex items-center justify-between">
        <span class="text-[10px] text-brand-text-muted font-extrabold uppercase tracking-wider font-['Outfit',sans-serif]">Categorías:</span>
      </div>
      <div class="flex items-center gap-2 overflow-x-auto pb-1 scrollbar-none" id="category-filters-container">
        <button 
          data-filter-category="todos" 
          class="px-3 py-1.5 text-xs font-black rounded-xl border border-transparent bg-brand-primary text-white shadow-lg shadow-brand-primary/25 transition-all cursor-pointer active:scale-95 shrink-0 duration-300"
        >
          Todas
        </button>
        {categories.map(cat => (
          <button 
            data-filter-category={cat.data.slug}
            class="px-3 py-1.5 text-xs font-semibold rounded-xl border border-brand-card-border bg-brand-bg/40 text-brand-text-muted hover:text-brand-text hover:border-brand-primary/30 transition-all cursor-pointer active:scale-95 shrink-0 duration-200"
          >
            {cat.data.icon ? `${cat.data.icon} ` : ''}{cat.data.name}
          </button>
        ))}
      </div>
    </div>

    <!-- Divisor -->
    <div class="border-t border-brand-card-border/60"></div>

    <!-- Filtros de Plataforma / Dispositivo -->
    <div class="flex flex-col gap-2">
      <span class="text-[10px] text-brand-text-muted font-extrabold uppercase tracking-wider font-['Outfit',sans-serif]">Dispositivos / OS:</span>
      <div class="flex items-center gap-2 overflow-x-auto pb-1 scrollbar-none" id="platform-filters-container">
        <button 
          data-filter-platform="todos" 
          class="px-3 py-1.5 text-xs font-black rounded-xl border border-transparent bg-brand-primary text-white shadow-lg shadow-brand-primary/25 transition-all cursor-pointer active:scale-95 shrink-0 duration-300"
        >
          Cualquiera
        </button>
        {platforms.map(plat => (
          <button 
            data-filter-platform={plat.id}
            class="px-3 py-1.5 text-xs font-semibold rounded-xl border border-brand-card-border bg-brand-bg/40 text-brand-text-muted hover:text-brand-text hover:border-brand-primary/30 transition-all cursor-pointer active:scale-95 shrink-0 duration-200"
          >
            {plat.name}
          </button>
        ))}
      </div>
    </div>
  </div>
</div>
