---
// src/components/SearchBar.astro
import { getCollection } from 'astro:content';

const categories = await getCollection('categories');

const platforms = [
  { id: 'web', name: 'Web' },
  { id: 'windows', name: 'Windows' },
  { id: 'mac', name: 'macOS' },
  { id: 'linux', name: 'Linux' },
  { id: 'android', name: 'Android' },
  { id: 'ios', name: 'iOS' }
];
---

<div class="w-full mb-4 rounded-xl border border-brand-card-border bg-brand-card-bg/80 p-3 shadow-lg shadow-black/5 sm:p-4" aria-label="Buscar y filtrar herramientas de IA">
  <label id="buscador-ia-title" for="search-input" class="sr-only">Buscar herramienta de IA por nombre</label>
  <p id="search-helper" class="sr-only">Busca por nombre y acota por categoría o plataforma sin salir del listado.</p>
  <div class="flex min-h-14 items-center gap-3 rounded-lg border border-brand-card-border bg-brand-bg/45 px-3 transition-colors focus-within:border-brand-primary/50">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 text-brand-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z" />
    </svg>
    <input
      type="search"
      id="search-input"
      aria-describedby="search-helper"
      placeholder="Buscar ChatGPT, Gemini, Claude, Ollama, Cursor..."
      autocomplete="off"
      class="min-w-0 flex-1 bg-transparent py-3 text-base text-brand-text placeholder-brand-text-muted/55 focus:outline-none"
    />
    <button id="btn-clear-search" class="hidden inline-flex min-h-10 min-w-10 items-center justify-center rounded-md text-brand-text-muted transition-colors hover:bg-brand-card-bg hover:text-brand-primary cursor-pointer" aria-label="Limpiar búsqueda">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="h-4 w-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div class="mt-4 grid gap-3 lg:grid-cols-[1fr_auto]">
    <div class="min-w-0">
      <div class="mb-2 flex items-center justify-between gap-3">
        <span class="text-[11px] font-bold uppercase text-brand-text-muted">Categoría</span>
      </div>
      <div class="flex items-center gap-2 overflow-x-auto pb-1 scrollbar-none" id="category-filters-container">
        <button
          data-filter-category="todos"
          class="min-h-10 shrink-0 rounded-md border border-transparent bg-brand-primary px-3 py-2 text-xs font-bold text-white transition-colors cursor-pointer active:scale-[0.98]"
        >
          Todas
        </button>
        {categories.map(cat => (
          <button
            data-filter-category={cat.data.slug}
            class="min-h-10 shrink-0 rounded-md border border-brand-card-border bg-brand-bg/40 px-3 py-2 text-xs font-semibold text-brand-text-muted transition-colors hover:border-brand-primary/30 hover:text-brand-text cursor-pointer active:scale-[0.98]"
          >
            {cat.data.name}
          </button>
        ))}
      </div>
    </div>

    <div class="min-w-0 lg:w-[25rem]">
      <div class="mb-2 flex items-center justify-between gap-3">
        <span class="text-[11px] font-bold uppercase text-brand-text-muted">Plataforma</span>
      </div>
      <div class="flex items-center gap-2 overflow-x-auto pb-1 scrollbar-none" id="platform-filters-container">
        <button
          data-filter-platform="todos"
          class="min-h-10 shrink-0 rounded-md border border-transparent bg-brand-primary px-3 py-2 text-xs font-bold text-white transition-colors cursor-pointer active:scale-[0.98]"
        >
          Cualquiera
        </button>
        {platforms.map(plat => (
          <button
            data-filter-platform={plat.id}
            class="min-h-10 shrink-0 rounded-md border border-brand-card-border bg-brand-bg/40 px-3 py-2 text-xs font-semibold text-brand-text-muted transition-colors hover:border-brand-primary/30 hover:text-brand-text cursor-pointer active:scale-[0.98]"
          >
            {plat.name}
          </button>
        ))}
      </div>
    </div>
  </div>
</div>
