---
// src/components/SearchBar.astro
import { getCollection } from 'astro:content';
import { useTranslations } from '../i18n/ui';

interface Props {
  variant?: 'hero' | 'filters';
}

const { variant = 'hero' } = Astro.props;
const categories = await getCollection('categories');
const isHero = variant === 'hero';

const lang = (Astro.currentLocale || 'es') as 'es' | 'sv' | 'it';
const t = useTranslations(lang);

const platforms = [
  { id: 'web', name: 'Web' },
  { id: 'windows', name: 'Windows' },
  { id: 'mac', name: 'macOS' },
  { id: 'linux', name: 'Linux' },
  { id: 'android', name: 'Android' },
  { id: 'ios', name: 'iOS' }
];

const placeholders = {
  es: '¿Qué IA quieres descargar?',
  sv: 'Vilken AI vill du ladda ner?',
  it: 'Quale IA vuoi scaricare?'
};

const searchBtnLabels = {
  es: 'Buscar',
  sv: 'Sök',
  it: 'Cerca'
};

const categoryNames: Record<string, Record<string, string>> = {
  'asistentes-ia': { es: 'Asistentes', sv: 'Assistenter', it: 'Assistenti' },
  programacion: { es: 'Programación', sv: 'Programmering', it: 'Programmazione' },
  'modelos-locales': { es: 'Modelos locales', sv: 'Lokala modeller', it: 'Modelli locali' },
  'generacion-imagenes': { es: 'Imagen', sv: 'Bild', it: 'Immagini' },
  'video-ia': { es: 'Video', sv: 'Video', it: 'Video' }
};
---

<div class={isHero ? 'w-full' : 'mb-4 rounded-xl border border-brand-card-border bg-brand-card-bg/60 p-2'} aria-label={isHero ? (lang === 'sv' ? 'Sök AI-verktyg' : lang === 'it' ? 'Cerca strumento IA' : 'Buscar herramienta de IA') : (lang === 'sv' ? 'Filtrera AI-verktyg' : lang === 'it' ? 'Filtra strumenti IA' : 'Filtrar herramientas de IA')}>
  {isHero && (
    <>
      <label id="buscador-ia-title" for="search-input" class="sr-only">{lang === 'sv' ? 'Sök AI-verktyg efter namn' : lang === 'it' ? 'Cerca strumento IA per nome' : 'Buscar herramienta de IA por nombre'}</label>
      <p id="search-helper" class="sr-only">{lang === 'sv' ? 'Skriv namnet på ett verktyg för att filtrera.' : lang === 'it' ? 'Scrivi il nome di uno strumento per filtrare.' : 'Escribe el nombre de una herramienta de IA para filtrar el índice de descargas oficiales.'}</p>
      <div class="rounded-2xl border border-brand-primary/25 bg-brand-card-bg p-2 shadow-2xl shadow-emerald-950/20">
        <div class="flex min-h-14 items-center gap-2 rounded-xl border border-brand-card-border bg-brand-bg/55 px-3 transition-colors focus-within:border-brand-primary/60">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 text-brand-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z" />
          </svg>
          <input
            type="search"
            id="search-input"
            aria-describedby="search-helper"
            placeholder={placeholders[lang]}
            autocomplete="off"
            class="min-w-0 flex-1 bg-transparent py-3 text-base text-brand-text placeholder-brand-text-muted/65 focus:outline-none"
          />
          <button id="btn-clear-search" class="hidden inline-flex min-h-10 min-w-10 items-center justify-center rounded-md text-brand-text-muted transition-colors hover:bg-brand-card-bg hover:text-brand-primary cursor-pointer" aria-label={lang === 'sv' ? 'Rensa sökning' : lang === 'it' ? 'Cancella ricerca' : 'Limpiar búsqueda'}>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="h-4 w-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>
          <a href="#directorio" class="inline-flex min-h-10 shrink-0 items-center justify-center rounded-lg bg-brand-primary px-3 text-xs font-black text-white transition-colors hover:bg-brand-primary-hover active:scale-[0.98] sm:px-4">
            {searchBtnLabels[lang]}
          </a>
        </div>
      </div>
    </>
  )}

  {!isHero && (
    <details class="group">
      <summary class="flex min-h-11 cursor-pointer list-none items-center justify-between gap-3 rounded-lg px-3 text-xs font-black uppercase text-brand-text">
        {lang === 'sv' ? 'Filtrera Resultat' : lang === 'it' ? 'Filtra Risultati' : 'Afinar resultados'}
        <span class="text-brand-primary transition-transform group-open:rotate-180" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
            <path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6" />
          </svg>
        </span>
      </summary>
      <div class="grid gap-3 px-1 pb-2 pt-2 lg:grid-cols-[1fr_auto]">
        <div class="min-w-0">
          <div class="mb-2 flex items-center justify-between gap-3">
            <span class="text-[11px] font-bold uppercase text-brand-text-muted">{lang === 'sv' ? 'Kategori' : lang === 'it' ? 'Categoria' : 'Categoría'}</span>
          </div>
          <div class="flex items-center gap-2 overflow-x-auto pb-1 scrollbar-none" id="category-filters-container">
            <button
              data-filter-category="todos"
              class="min-h-10 shrink-0 rounded-md border border-transparent bg-brand-primary px-3 py-2 text-xs font-bold text-white transition-colors cursor-pointer active:scale-[0.98]"
            >
              {lang === 'sv' ? 'Alla' : lang === 'it' ? 'Tutte' : 'Todas'}
            </button>
            {categories.map(cat => (
              <button
                data-filter-category={cat.data.slug}
                class="min-h-10 shrink-0 rounded-md border border-brand-card-border bg-brand-bg/40 px-3 py-2 text-xs font-semibold text-brand-text-muted transition-colors hover:border-brand-primary/30 hover:text-brand-text cursor-pointer active:scale-[0.98]"
              >
                {categoryNames[cat.data.slug]?.[lang] ?? cat.data.name}
              </button>
            ))}
          </div>
        </div>

        <div class="min-w-0 lg:w-[25rem]">
          <div class="mb-2 flex items-center justify-between gap-3">
            <span class="text-[11px] font-bold uppercase text-brand-text-muted">{lang === 'sv' ? 'Plattform' : lang === 'it' ? 'Piattaforma' : 'Plataforma'}</span>
          </div>
          <div class="flex items-center gap-2 overflow-x-auto pb-1 scrollbar-none" id="platform-filters-container">
            <button
              data-filter-platform="todos"
              class="min-h-10 shrink-0 rounded-md border border-transparent bg-brand-primary px-3 py-2 text-xs font-bold text-white transition-colors cursor-pointer active:scale-[0.98]"
            >
              {lang === 'sv' ? 'Alla' : lang === 'it' ? 'Qualsiasi' : 'Cualquiera'}
            </button>
            {platforms.map(plat => (
              <button
                data-filter-platform={plat.id}
                class="min-h-10 shrink-0 rounded-md border border-brand-card-border bg-brand-bg/40 px-3 py-2 text-xs font-semibold text-brand-text-muted transition-colors hover:border-brand-primary/30 hover:text-brand-text cursor-pointer active:scale-[0.98]"
              >
                {plat.name}
              </button>
            ))}
          </div>
        </div>
      </div>
    </details>
  )}
</div>
