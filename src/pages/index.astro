---
// src/pages/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import ToolCard from '../components/ToolCard.astro';

const tools = await getCollection('tools');

// Sort tools by trustLevel (official first, then verified, then pending)
const sortedTools = [...tools].sort((a, b) => {
  const priorities = { official: 3, verified: 2, 'pending-review': 1 };
  const valA = priorities[a.data.trustLevel] || 0;
  const valB = priorities[b.data.trustLevel] || 0;
  return valB - valA;
});

const pageTitle = "Directorio Confiable de Herramientas de Inteligencia Artificial";
const pageDesc = "Descarga de forma segura aplicaciones oficiales de ChatGPT, Gemini, Claude, Ollama, Cursor y más. Sin malware ni mirrors, directo a las fuentes oficiales.";

// Schema para el listado de herramientas
const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Directorio de Herramientas de IA y Descargas Oficiales",
  "description": "Lista verificada de aplicaciones de inteligencia artificial y enlaces de descarga oficial segura.",
  "numberOfItems": sortedTools.length,
  "itemListElement": sortedTools.map((t, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "url": Astro.url.origin + `/${t.data.slug}`,
    "name": t.data.name
  }))
};
---

<BaseLayout title={pageTitle} description={pageDesc} jsonLd={schemaItemList}>
  <!-- Hero Section -->
  <section class="text-center py-16 relative overflow-hidden" aria-labelledby="hero-title">
    <div class="relative z-10 max-w-3xl mx-auto px-4">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 text-[11px] font-black tracking-wider uppercase rounded-full bg-brand-primary/10 text-brand-primary border border-brand-primary/20 mb-6">
        Enlaces 100% Oficiales y Seguros
      </span>
      
      <h1 id="hero-title" class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-brand-text mb-6 font-['Outfit',sans-serif] leading-[1.1]">
        Directorio Confiable de <br class="hidden sm:inline" />
        <span class="bg-gradient-to-r from-brand-primary via-fuchsia-400 to-brand-secondary bg-clip-text text-transparent drop-shadow-sm">
          Herramientas de IA
        </span>
      </h1>
      
      <p class="text-base sm:text-lg text-brand-text-muted mb-8 max-w-2xl mx-auto font-medium leading-relaxed">
        Evita virus, instaladores modificados y extensiones falsas. Te guiamos directamente a las descargas oficiales del desarrollador.
      </p>
    </div>
  </section>

  <!-- Buscador y Filtros -->
  <section id="directorio" class="scroll-mt-20">
    <SearchBar />

    <!-- Grid de Herramientas -->
    <div 
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 transition-all duration-300" 
      id="tools-grid"
    >
      {sortedTools.map(tool => (
        <ToolCard tool={tool.data} />
      ))}
    </div>

    <!-- Mensaje de Búsqueda sin Resultados -->
    <div id="empty-state" class="hidden w-full text-center py-16 bg-brand-card-bg/10 border border-dashed border-brand-card-border rounded-2xl p-8 mt-6">
      <div class="text-4xl mb-4" aria-hidden="true">🔍</div>
      <h3 class="text-lg font-bold text-brand-text mb-2">No encontramos herramientas con estos filtros</h3>
      <p class="text-sm text-brand-text-muted max-w-md mx-auto mb-6">Prueba escribiendo otra palabra o restableciendo los filtros de categoría y dispositivo.</p>
      <button 
        id="reset-all-filters-btn" 
        class="px-5 py-2.5 text-xs font-bold rounded-xl bg-brand-primary/10 text-brand-primary border border-brand-primary/20 hover:bg-brand-primary/20 transition-all cursor-pointer"
      >
        Restablecer Filtros
      </button>
    </div>
  </section>

  <!-- Script de Filtro Client-Side (Vanilla JS - estilo Vet24) -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('search-input');
      const clearBtn = document.getElementById('btn-clear-search');
      const toolsGrid = document.getElementById('tools-grid');
      const emptyState = document.getElementById('empty-state');
      const resetBtn = document.getElementById('reset-all-filters-btn');
      
      const categoryButtons = document.querySelectorAll('#category-filters-container button');
      const platformButtons = document.querySelectorAll('#platform-filters-container button');
      const cards = document.querySelectorAll('#tools-grid article');
      
      let searchQuery = '';
      let activeCategory = 'todos';
      let activePlatform = 'todos';
      
      // Aplicar filtros completos
      const applyFilters = () => {
        let visibleCount = 0;
        
        cards.forEach(card => {
          const name = card.getAttribute('data-name') || '';
          const slug = card.getAttribute('data-slug') || '';
          const cardCategories = (card.getAttribute('data-categories') || '').split(',');
          const cardPlatforms = (card.getAttribute('data-platforms') || '').split(',');
          
          let matchesSearch = true;
          let matchesCategory = true;
          let matchesPlatform = true;
          
          // Filtro de búsqueda
          if (searchQuery) {
            const normalizedQuery = searchQuery.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
            const normalizedName = name.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
            matchesSearch = normalizedName.includes(normalizedQuery) || slug.includes(normalizedQuery);
          }
          
          // Filtro de categoría
          if (activeCategory !== 'todos') {
            matchesCategory = cardCategories.includes(activeCategory);
          }
          
          // Filtro de plataforma
          if (activePlatform !== 'todos') {
            matchesPlatform = cardPlatforms.includes(activePlatform);
          }
          
          if (matchesSearch && matchesCategory && matchesPlatform) {
            card.classList.remove('hidden');
            visibleCount++;
          } else {
            card.classList.add('hidden');
          }
        });
        
        // Estado vacío
        if (visibleCount === 0) {
          toolsGrid.classList.add('hidden');
          emptyState.classList.remove('hidden');
        } else {
          toolsGrid.classList.remove('hidden');
          emptyState.classList.add('hidden');
        }
      };
      
      // Evento de búsqueda
      searchInput?.addEventListener('input', () => {
        searchQuery = searchInput.value.trim().toLowerCase();
        if (clearBtn) {
          clearBtn.classList.toggle('hidden', !searchQuery);
        }
        applyFilters();
      });
      
      clearBtn?.addEventListener('click', () => {
        if (searchInput) searchInput.value = '';
        searchQuery = '';
        clearBtn.classList.add('hidden');
        applyFilters();
      });
      
      // Evento de Categoría
      categoryButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          categoryButtons.forEach(b => {
            b.classList.remove('bg-brand-primary', 'text-white', 'border-transparent');
            b.classList.add('bg-brand-bg/40', 'text-brand-text-muted', 'border-brand-card-border');
          });
          btn.classList.add('bg-brand-primary', 'text-white', 'border-transparent');
          btn.classList.remove('bg-brand-bg/40', 'text-brand-text-muted', 'border-brand-card-border');
          
          activeCategory = btn.getAttribute('data-filter-category') || 'todos';
          applyFilters();
        });
      });
      
      // Evento de Plataforma
      platformButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          platformButtons.forEach(b => {
            b.classList.remove('bg-brand-primary', 'text-white', 'border-transparent');
            b.classList.add('bg-brand-bg/40', 'text-brand-text-muted', 'border-brand-card-border');
          });
          btn.classList.add('bg-brand-primary', 'text-white', 'border-transparent');
          btn.classList.remove('bg-brand-bg/40', 'text-brand-text-muted', 'border-brand-card-border');
          
          activePlatform = btn.getAttribute('data-filter-platform') || 'todos';
          applyFilters();
        });
      });
      
      // Reset completo
      const resetAll = () => {
        searchQuery = '';
        activeCategory = 'todos';
        activePlatform = 'todos';
        
        if (searchInput) searchInput.value = '';
        if (clearBtn) clearBtn.classList.add('hidden');
        
        // Reset botones categorías
        categoryButtons.forEach(b => {
          const isAll = b.getAttribute('data-filter-category') === 'todos';
          b.classList.toggle('bg-brand-primary', isAll);
          b.classList.toggle('text-white', isAll);
          b.classList.toggle('border-transparent', isAll);
          b.classList.toggle('bg-brand-bg/40', !isAll);
          b.classList.toggle('text-brand-text-muted', !isAll);
          b.classList.toggle('border-brand-card-border', !isAll);
        });
        
        // Reset botones plataformas
        platformButtons.forEach(b => {
          const isAll = b.getAttribute('data-filter-platform') === 'todos';
          b.classList.toggle('bg-brand-primary', isAll);
          b.classList.toggle('text-white', isAll);
          b.classList.toggle('border-transparent', isAll);
          b.classList.toggle('bg-brand-bg/40', !isAll);
          b.classList.toggle('text-brand-text-muted', !isAll);
          b.classList.toggle('border-brand-card-border', !isAll);
        });
        
        applyFilters();
      };
      
      resetBtn?.addEventListener('click', resetAll);
    });
  </script>
</BaseLayout>
