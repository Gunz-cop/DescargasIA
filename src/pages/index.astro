---
// src/pages/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import ToolCard from '../components/ToolCard.astro';

const tools = await getCollection('tools');
const categories = await getCollection('categories');

// Sort tools by trustLevel (official first, then verified, then pending)
const sortedTools = [...tools].sort((a, b) => {
  const priorities = { official: 3, verified: 2, 'pending-review': 1 };
  const valA = priorities[a.data.trustLevel] || 0;
  const valB = priorities[b.data.trustLevel] || 0;
  return valB - valA;
});

const pageTitle = "Descarga IA desde canales oficiales | DescargasIA";
const pageDesc = "Índice editorial en español para encontrar canales oficiales de ChatGPT, Gemini, Claude, Ollama, Cursor y más. Sin mirrors, APKs modificados ni instaladores falsos.";

const categoryStyles: Record<string, { label: string; accent: string; surface: string; description: string }> = {
  'asistentes-ia': {
    label: 'Asistentes',
    accent: 'bg-emerald-400',
    surface: 'border-emerald-400/30 bg-emerald-500/10',
    description: 'Chatbots y asistentes web o nativos'
  },
  programacion: {
    label: 'Programación',
    accent: 'bg-sky-400',
    surface: 'border-sky-400/30 bg-sky-500/10',
    description: 'IDEs, copilotos y herramientas dev'
  },
  'modelos-locales': {
    label: 'Modelos locales',
    accent: 'bg-amber-400',
    surface: 'border-amber-400/30 bg-amber-500/10',
    description: 'Ejecución local y gestores de modelos'
  },
  'generacion-imagenes': {
    label: 'Imagen',
    accent: 'bg-fuchsia-400',
    surface: 'border-fuchsia-400/30 bg-fuchsia-500/10',
    description: 'Generación y edición visual con IA'
  },
  'video-ia': {
    label: 'Video',
    accent: 'bg-cyan-400',
    surface: 'border-cyan-400/30 bg-cyan-500/10',
    description: 'Creación y edición de video con IA'
  }
};

const categoryStats = categories.map((cat) => {
  const count = tools.filter((tool) => tool.data.categories.includes(cat.data.slug)).length;
  return {
    slug: cat.data.slug,
    name: categoryStyles[cat.data.slug]?.label ?? cat.data.name,
    count,
    countLabel: count === 1 ? '1 ficha' : `${count} fichas`,
    description: categoryStyles[cat.data.slug]?.description ?? cat.data.description,
    accent: categoryStyles[cat.data.slug]?.accent ?? 'bg-brand-primary',
    surface: categoryStyles[cat.data.slug]?.surface ?? 'border-brand-card-border bg-brand-card-bg'
  };
});

// Schema para el listado de herramientas
const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Directorio de Herramientas de IA y Descargas Oficiales",
  "description": "Lista verificada de aplicaciones de inteligencia artificial y enlaces de descarga oficial segura.",
  "numberOfItems": sortedTools.length,
  "itemListElement": sortedTools.map((t, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "url": Astro.url.origin + `/${t.data.slug}`,
    "name": t.data.name
  }))
};
---

<BaseLayout title={pageTitle} description={pageDesc} jsonLd={schemaItemList}>
  <!-- Hero Section -->
  <section class="relative py-10 sm:py-14" aria-labelledby="hero-title">
    <div class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
      <div>
        <span class="mb-5 inline-flex items-center gap-2 rounded border border-brand-primary/30 bg-brand-primary/10 px-3 py-1 text-[11px] font-black uppercase text-brand-primary">
          Índice editorial de seguridad
        </span>

        <h1 id="hero-title" class="mb-5 max-w-4xl text-4xl font-black leading-[1.02] tracking-tight text-brand-text sm:text-6xl md:text-7xl font-['Outfit',sans-serif]">
          Antes de descargar IA, confirma el origen.
        </h1>

        <p class="max-w-2xl text-base leading-relaxed text-brand-text-muted sm:text-lg">
          DescargasIA conecta búsquedas de descarga con dominios oficiales, tiendas legítimas y páginas reales del desarrollador. Sin mirrors, sin APKs de terceros y sin instaladores alojados aquí.
        </p>
      </div>

      <aside class="rounded-xl border border-brand-card-border bg-brand-card-bg p-4" aria-label="Protocolo editorial">
        <p class="mb-3 text-[11px] font-black uppercase text-brand-primary">Protocolo editorial</p>
        <div class="grid gap-2">
          <div class="flex items-start gap-3 rounded-lg border border-brand-card-border bg-brand-bg/35 p-3">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-brand-success" aria-hidden="true"></span>
            <div>
              <p class="text-sm font-bold text-brand-text">Mostramos el dominio</p>
              <p class="text-xs leading-relaxed text-brand-text-muted">El usuario ve la fuente antes de salir del índice.</p>
            </div>
          </div>
          <div class="flex items-start gap-3 rounded-lg border border-brand-card-border bg-brand-bg/35 p-3">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-brand-warning-text" aria-hidden="true"></span>
            <div>
              <p class="text-sm font-bold text-brand-text">Marcamos advertencias</p>
              <p class="text-xs leading-relaxed text-brand-text-muted">Señalamos riesgos editoriales sin prometer auditorías técnicas.</p>
            </div>
          </div>
          <div class="flex items-start gap-3 rounded-lg border border-brand-card-border bg-brand-bg/35 p-3">
            <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-brand-secondary" aria-hidden="true"></span>
            <div>
              <p class="text-sm font-bold text-brand-text">Filtramos por uso real</p>
              <p class="text-xs leading-relaxed text-brand-text-muted">Categoría y plataforma quedan visibles para decidir rápido.</p>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="mb-8" aria-label="Principios de confianza">
    <div class="grid gap-2 rounded-xl border border-brand-card-border bg-brand-card-bg p-3 sm:grid-cols-4">
      <div class="rounded-lg border border-brand-card-border bg-brand-bg/35 px-3 py-3">
        <p class="text-xs font-bold text-brand-text">Sin mirrors</p>
        <p class="text-[11px] leading-relaxed text-brand-text-muted">Evitamos copias y páginas intermediarias.</p>
      </div>
      <div class="rounded-lg border border-brand-card-border bg-brand-bg/35 px-3 py-3">
        <p class="text-xs font-bold text-brand-text">Sin APKs de terceros</p>
        <p class="text-[11px] leading-relaxed text-brand-text-muted">Priorizamos tiendas y dominios oficiales.</p>
      </div>
      <div class="rounded-lg border border-brand-card-border bg-brand-bg/35 px-3 py-3">
        <p class="text-xs font-bold text-brand-text">Sin instaladores alojados</p>
        <p class="text-[11px] leading-relaxed text-brand-text-muted">No redistribuimos ejecutables.</p>
      </div>
      <div class="rounded-lg border border-brand-success-border bg-brand-success-bg px-3 py-3">
        <p class="text-xs font-bold text-brand-success">Revisión visible</p>
        <p class="text-[11px] leading-relaxed text-brand-text-muted">Cada ficha expone fecha y fuente principal.</p>
      </div>
    </div>
  </section>

  <!-- Buscador y Filtros -->
  <section id="directorio" class="scroll-mt-20">
    <SearchBar />

    <div class="mb-7 grid gap-3 sm:grid-cols-2 lg:grid-cols-5" aria-label="Categorías editoriales">
      {categoryStats.map((cat) => (
        <a href={`/categoria/${cat.slug}`} class={`group relative overflow-hidden rounded-xl border p-4 transition-colors hover:border-brand-primary/40 ${cat.surface}`}>
          <span class={`absolute inset-x-0 top-0 h-1 ${cat.accent}`} aria-hidden="true"></span>
          <span class="font-mono text-[10px] font-bold uppercase text-brand-text-muted">{cat.countLabel}</span>
          <p class="mt-2 text-sm font-black text-brand-text group-hover:text-brand-primary">{cat.name}</p>
          <p class="mt-1 text-[11px] leading-relaxed text-brand-text-muted">{cat.description}</p>
        </a>
      ))}
    </div>

    <div class="mb-4 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="text-[11px] font-black uppercase text-brand-primary">Fuentes indexadas</p>
        <h2 class="text-2xl font-black tracking-tight text-brand-text font-['Outfit',sans-serif]">Herramientas verificadas</h2>
      </div>
      <p class="text-xs text-brand-text-muted">{sortedTools.length} fichas editoriales disponibles</p>
    </div>

    <!-- Grid de Herramientas -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 transition-all duration-300"
      id="tools-grid"
    >
      {sortedTools.map(tool => (
        <ToolCard tool={tool.data} />
      ))}
    </div>

    <!-- Mensaje de Búsqueda sin Resultados -->
    <div id="empty-state" class="hidden w-full text-center py-16 bg-brand-card-bg border border-dashed border-brand-card-border rounded-lg p-8 mt-6">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full border border-brand-card-border bg-brand-bg/35 text-brand-primary" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15Z" />
        </svg>
      </div>
      <h3 class="text-lg font-bold text-brand-text mb-2">No encontramos una fuente con esos filtros</h3>
      <p class="text-sm text-brand-text-muted max-w-md mx-auto mb-6">Prueba con otro nombre o restablece categoría y plataforma.</p>
      <button
        id="reset-all-filters-btn"
        class="min-h-11 px-5 py-2.5 text-xs font-bold rounded-md bg-brand-primary text-white border border-brand-primary hover:bg-brand-primary-hover transition-colors cursor-pointer"
      >
        Restablecer filtros
      </button>
    </div>
  </section>

  <!-- Script de Filtro Client-Side (Vanilla JS) -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('search-input');
      const clearBtn = document.getElementById('btn-clear-search');
      const toolsGrid = document.getElementById('tools-grid');
      const emptyState = document.getElementById('empty-state');
      const resetBtn = document.getElementById('reset-all-filters-btn');
      
      const categoryButtons = document.querySelectorAll('#category-filters-container button');
      const platformButtons = document.querySelectorAll('#platform-filters-container button');
      const cards = document.querySelectorAll('#tools-grid article');
      
      let searchQuery = '';
      let activeCategory = 'todos';
      let activePlatform = 'todos';
      
      // Aplicar filtros completos
      const applyFilters = () => {
        let visibleCount = 0;
        
        cards.forEach(card => {
          const name = card.getAttribute('data-name') || '';
          const slug = card.getAttribute('data-slug') || '';
          const cardCategories = (card.getAttribute('data-categories') || '').split(',');
          const cardPlatforms = (card.getAttribute('data-platforms') || '').split(',');
          
          let matchesSearch = true;
          let matchesCategory = true;
          let matchesPlatform = true;
          
          // Filtro de búsqueda
          if (searchQuery) {
            const normalizedQuery = searchQuery.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
            const normalizedName = name.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
            matchesSearch = normalizedName.includes(normalizedQuery) || slug.includes(normalizedQuery);
          }
          
          // Filtro de categoría
          if (activeCategory !== 'todos') {
            matchesCategory = cardCategories.includes(activeCategory);
          }
          
          // Filtro de plataforma
          if (activePlatform !== 'todos') {
            matchesPlatform = cardPlatforms.includes(activePlatform);
          }
          
          if (matchesSearch && matchesCategory && matchesPlatform) {
            card.classList.remove('hidden');
            visibleCount++;
          } else {
            card.classList.add('hidden');
          }
        });
        
        // Estado vacío
        if (visibleCount === 0) {
          toolsGrid.classList.add('hidden');
          emptyState.classList.remove('hidden');
        } else {
          toolsGrid.classList.remove('hidden');
          emptyState.classList.add('hidden');
        }
      };
      
      // Evento de búsqueda
      searchInput?.addEventListener('input', () => {
        searchQuery = searchInput.value.trim().toLowerCase();
        if (clearBtn) {
          clearBtn.classList.toggle('hidden', !searchQuery);
        }
        applyFilters();
      });
      
      clearBtn?.addEventListener('click', () => {
        if (searchInput) searchInput.value = '';
        searchQuery = '';
        clearBtn.classList.add('hidden');
        applyFilters();
      });
      
      // Evento de Categoría
      categoryButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          categoryButtons.forEach(b => {
            b.classList.remove('bg-brand-primary', 'text-white', 'border-transparent');
            b.classList.add('bg-brand-bg/40', 'text-brand-text-muted', 'border-brand-card-border');
          });
          btn.classList.add('bg-brand-primary', 'text-white', 'border-transparent');
          btn.classList.remove('bg-brand-bg/40', 'text-brand-text-muted', 'border-brand-card-border');
          
          activeCategory = btn.getAttribute('data-filter-category') || 'todos';
          applyFilters();
        });
      });
      
      // Evento de Plataforma
      platformButtons.forEach(btn => {
        btn.addEventListener('click', () => {
          platformButtons.forEach(b => {
            b.classList.remove('bg-brand-primary', 'text-white', 'border-transparent');
            b.classList.add('bg-brand-bg/40', 'text-brand-text-muted', 'border-brand-card-border');
          });
          btn.classList.add('bg-brand-primary', 'text-white', 'border-transparent');
          btn.classList.remove('bg-brand-bg/40', 'text-brand-text-muted', 'border-brand-card-border');
          
          activePlatform = btn.getAttribute('data-filter-platform') || 'todos';
          applyFilters();
        });
      });
      
      // Reset completo
      const resetAll = () => {
        searchQuery = '';
        activeCategory = 'todos';
        activePlatform = 'todos';
        
        if (searchInput) searchInput.value = '';
        if (clearBtn) clearBtn.classList.add('hidden');
        
        // Reset botones categorías
        categoryButtons.forEach(b => {
          const isAll = b.getAttribute('data-filter-category') === 'todos';
          b.classList.toggle('bg-brand-primary', isAll);
          b.classList.toggle('text-white', isAll);
          b.classList.toggle('border-transparent', isAll);
          b.classList.toggle('bg-brand-bg/40', !isAll);
          b.classList.toggle('text-brand-text-muted', !isAll);
          b.classList.toggle('border-brand-card-border', !isAll);
        });
        
        // Reset botones plataformas
        platformButtons.forEach(b => {
          const isAll = b.getAttribute('data-filter-platform') === 'todos';
          b.classList.toggle('bg-brand-primary', isAll);
          b.classList.toggle('text-white', isAll);
          b.classList.toggle('border-transparent', isAll);
          b.classList.toggle('bg-brand-bg/40', !isAll);
          b.classList.toggle('text-brand-text-muted', !isAll);
          b.classList.toggle('border-brand-card-border', !isAll);
        });
        
        applyFilters();
      };
      
      resetBtn?.addEventListener('click', resetAll);
    });
  </script>
</BaseLayout>
