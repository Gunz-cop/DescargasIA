---
// src/pages/ir/[tool]/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import linkzipCache from '../../../linkzip-cache.json';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map(tool => ({
    params: { tool: tool.data.slug },
    props: { tool }
  }));
}

const { tool } = Astro.props;
const officialUrl = tool.data.officialWebsite;
const targetUrl = (linkzipCache as Record<string, string>)[officialUrl] ?? officialUrl;
---

<BaseLayout 
  title={`Redirigiendo a la web oficial de ${tool.data.name} | DescargasIA`} 
  description={`Redirección de salida segura al sitio web oficial de ${tool.data.name}.`}
>
  <div class="max-w-md mx-auto text-center py-20 flex flex-col items-center justify-center gap-6">
    <!-- Spinner animado premium -->
    <div class="relative w-16 h-16" aria-hidden="true">
      <div class="absolute inset-0 rounded-full border-4 border-brand-primary/25"></div>
      <div class="absolute inset-0 rounded-full border-4 border-t-brand-primary animate-spin"></div>
    </div>
    
    <div class="flex flex-col gap-2">
      <h1 class="text-xl font-black text-brand-text font-['Outfit']">Redirección segura en curso</h1>
      <p class="text-xs text-brand-text-muted leading-relaxed">
        Te estamos conectando de forma transparente con la web oficial de <strong class="text-brand-text">{tool.data.name}</strong>.
      </p>
      <p class="text-xs font-semibold text-brand-primary">
        Destino verificado: {new URL(officialUrl).hostname}
      </p>
      <p class="text-[10px] text-brand-text-muted/60 mt-2">
        Si la redirección no se completa automáticamente en unos segundos, haz clic en el botón inferior.
      </p>
    </div>

    <!-- Enlace directo visible por si falla la redirección -->
    <a 
      href={targetUrl} 
      id="redirect-link"
      class="w-full inline-flex items-center justify-center gap-2 px-6 py-3.5 text-xs font-extrabold rounded-xl bg-brand-primary text-white hover:bg-brand-primary-hover shadow-lg shadow-brand-primary/25 active:scale-[0.98] transition-all"
    >
      Continuar a {new URL(officialUrl).hostname}
    </a>
  </div>

  <!-- Meta-refresh de salida transparente en HTML -->
  <meta http-equiv="refresh" content={`0;url=${targetUrl}`} slot="head" />

  <!-- Redirección inmediata por JavaScript en cliente -->
  <script is:inline define:vars={{ url: targetUrl }}>
    if (url) {
      window.location.replace(url);
    }
  </script>
</BaseLayout>
