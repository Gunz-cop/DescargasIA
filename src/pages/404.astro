---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Página No Encontrada (404) - DescargasIA";
const pageDesc = "La página que buscas no existe o ha sido movida. Vuelve a nuestro directorio de herramientas oficiales de IA.";
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <div class="max-w-md mx-auto text-center py-20 flex flex-col items-center justify-center gap-6">
    <div class="relative">
      <div class="text-8xl font-black tracking-tight text-brand-primary opacity-25 select-none font-['Outfit']">404</div>
      <div class="absolute inset-0 flex items-center justify-center text-4xl" aria-hidden="true">⚠️</div>
    </div>
    
    <div class="flex flex-col gap-2">
      <h1 class="text-2xl font-black text-brand-text font-['Outfit']">Página no encontrada</h1>
      <p class="text-sm text-brand-text-muted leading-relaxed">
        El enlace que has seguido puede estar roto o la herramienta ha sido removida del directorio para actualización.
      </p>
    </div>

    <div class="border-t border-brand-card-border/60 w-full my-2"></div>

    <a 
      href="/" 
      class="inline-flex items-center justify-center gap-2 px-6 py-3.5 text-sm font-extrabold rounded-xl bg-brand-primary text-white hover:bg-brand-primary-hover shadow-lg shadow-brand-primary/25 active:scale-[0.98] transition-all"
    >
      Volver al Directorio
    </a>
  </div>
</BaseLayout>
