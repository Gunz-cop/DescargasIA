---
// src/pages/[lang]/ir/[tool]/[platform].astro
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import linkzipCache from '../../../../linkzip-cache.json';
import { languages } from '../../../../i18n/ui';

export async function getStaticPaths() {
  const locales = Object.keys(languages);
  const baseTools = await getCollection('toolsBase');
  const paths: any[] = [];
  
  for (const lang of locales) {
    for (const tool of baseTools) {
      for (const [platform, details] of Object.entries(tool.data.platforms)) {
        if (details) {
          paths.push({
            params: {
              lang,
              tool: tool.id,
              platform: platform
            },
            props: {
              tool,
              platform,
              details,
              lang
            }
          });
        }
      }
    }
  }
  
  return paths;
}

const { tool, platform, details, lang } = Astro.props as { tool: any; platform: string; details: any; lang: 'es' | 'sv' | 'it' };
const officialUrl = details.url;
const targetUrl = (linkzipCache as Record<string, string>)[officialUrl] ?? officialUrl;

const platformNames: Record<string, Record<string, string>> = {
  web: { es: 'Versión Web', sv: 'Webbversion', it: 'Versione Web' },
  windows: { es: 'Windows', sv: 'Windows', it: 'Windows' },
  mac: { es: 'macOS', sv: 'macOS', it: 'macOS' },
  linux: { es: 'Linux', sv: 'Linux', it: 'Linux' },
  android: { es: 'Android', sv: 'Android', it: 'Android' },
  ios: { es: 'iOS', sv: 'iOS', it: 'iOS' }
};
const platName = platformNames[platform]?.[lang] || platform;

const texts = {
  es: {
    title: `Redirigiendo a la descarga de ${tool.data.name} para ${platName} | FuenteAI`,
    desc: `Redirección de salida segura a la descarga oficial de ${tool.data.name} para la plataforma ${platName}.`,
    heading: 'Redirección segura en curso',
    connecting: `Te estamos conectando de forma transparente con la descarga oficial de `,
    destination: 'Destino verificado:',
    fallback: 'Si la redirección no se completa automáticamente en unos segundos, haz clic en el botón inferior.',
    btn: 'Continuar a'
  },
  sv: {
    title: `Omdirigerar till nedladdning av ${tool.name} för ${platName} | FuenteAI`,
    desc: `Säker omdirigering till officiell nedladdning av ${tool.name} för ${platName}.`,
    heading: 'Säker omdirigering pågår',
    connecting: `Vi ansluter dig nu till den officiella nedladdningen av `,
    destination: 'Verifierad destination:',
    fallback: 'Klicka på knappen nedan om du inte omdirigeras automatiskt inom några sekunder.',
    btn: 'Fortsätt till'
  },
  it: {
    title: `Reindirizzamento al download di ${tool.data.name} per ${platName} | FuenteAI`,
    desc: `Reindirizzamento sicuro al download ufficiale di ${tool.data.name} per la piattaforma ${platName}.`,
    heading: 'Reindirizzamento sicuro in corso',
    connecting: `Ti stiamo connettendo in modo trasparente al download ufficiale di `,
    destination: 'Destinazione verificata:',
    fallback: 'Se il reindirizzamento non avviene automaticamente entro pochi secondi, fai clic sul pulsante in basso.',
    btn: 'Continua su'
  }
};

const tx = texts[lang];
---

<BaseLayout title={tx.title} description={tx.desc} lang={lang}>
  <div class="max-w-md mx-auto text-center py-20 flex flex-col items-center justify-center gap-6">
    <div class="relative w-16 h-16" aria-hidden="true">
      <div class="absolute inset-0 rounded-full border-4 border-brand-primary/25"></div>
      <div class="absolute inset-0 rounded-full border-4 border-t-brand-primary animate-spin"></div>
    </div>
    
    <div class="flex flex-col gap-2">
      <h1 class="text-xl font-black text-brand-text font-['Outfit']">{tx.heading}</h1>
      <p class="text-xs text-brand-text-muted leading-relaxed">
        {tx.connecting}<strong class="text-brand-text">{tool.data.name}</strong> para <strong class="text-brand-text">{platName}</strong>.
      </p>
      <p class="text-xs font-semibold text-brand-primary">
        {tx.destination} {new URL(officialUrl).hostname}
      </p>
      <p class="text-[10px] text-brand-text-muted/60 mt-2">
        {tx.fallback}
      </p>
    </div>

    <a 
      href={targetUrl} 
      id="redirect-link"
      target="_blank"
      rel="noopener noreferrer"
      class="w-full inline-flex items-center justify-center gap-2 px-6 py-3.5 text-xs font-extrabold rounded-xl bg-brand-primary text-white hover:bg-brand-primary-hover shadow-lg shadow-brand-primary/25 active:scale-[0.98] transition-all"
    >
      {tx.btn} {new URL(officialUrl).hostname}
    </a>
  </div>

  <meta http-equiv="refresh" content={`0;url=${targetUrl}`} slot="head" />

  <script is:inline define:vars={{ url: targetUrl }}>
    if (url) {
      window.location.replace(url);
    }
  </script>
</BaseLayout>
