---
// src/pages/[lang]/categoria/[slug].astro
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolCard from '../../../components/ToolCard.astro';
import { getTranslatedTools } from '../../../utils/tools';
import { useTranslations, languages } from '../../../i18n/ui';

export async function getStaticPaths() {
  const locales = Object.keys(languages);
  const categories = await getCollection('categories');
  const paths = [];

  for (const lang of locales) {
    for (const cat of categories) {
      paths.push({
        params: { lang, slug: cat.data.slug },
        props: { cat, lang }
      });
    }
  }

  return paths;
}

const { cat, lang } = Astro.props as { cat: any; lang: 'es' | 'sv' | 'it' };
const t = useTranslations(lang);

// Obtener todas las herramientas de este idioma asociadas a esta categoría
const allTools = await getTranslatedTools(lang);
const tools = allTools.filter(t => t.categories.includes(cat.data.slug));

// Ordenar herramientas por confianza
const sortedTools = [...tools].sort((a, b) => {
  const priorities = { official: 3, verified: 2, 'pending-review': 1 };
  const valA = priorities[a.trustLevel] || 0;
  const valB = priorities[b.trustLevel] || 0;
  return valB - valA;
});

// Localizar textos de la categoría si es necesario
const catNames: Record<string, Record<string, string>> = {
  'asistentes-ia': {
    es: 'Asistentes IA',
    sv: 'AI-assistenter',
    it: 'Assistenti IA'
  },
  programacion: {
    es: 'Programación',
    sv: 'Programmering',
    it: 'Programmazione'
  },
  'modelos-locales': {
    es: 'Modelos locales',
    sv: 'Lokala modeller',
    it: 'Modelli locali'
  },
  'generacion-imagenes': {
    es: 'Generación de Imágenes',
    sv: 'Bildgenerering',
    it: 'Generazione immagini'
  },
  'video-ia': {
    es: 'Video IA',
    sv: 'AI-video',
    it: 'IA Video'
  }
};
const localizedCatName = catNames[cat.data.slug]?.[lang] ?? cat.data.name;

const pageTitle = lang === 'sv'
  ? `AI-verktyg inom ${localizedCatName} | FuenteAI`
  : lang === 'it'
    ? `Strumenti IA in ${localizedCatName} | FuenteAI`
    : `Descargas de herramientas en ${localizedCatName} | FuenteAI`;

const pageDesc = lang === 'sv'
  ? `Officiella nedladdningslänkar för ${localizedCatName}. Verifierade och säkra källor.`
  : lang === 'it'
    ? `Collegamenti ufficiali di download per ${localizedCatName}. Fonti verificate e sicure.`
    : `${cat.data.description} Enlaces de descarga oficiales y verificados de forma segura en FuenteAI.`;

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": lang === 'sv' ? 'Hem' : lang === 'it' ? 'Home' : 'Inicio',
      "item": `${Astro.url.origin}/${lang}`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": localizedCatName,
      "item": Astro.url.href
    }
  ]
};
---

<BaseLayout title={pageTitle} description={pageDesc} jsonLd={schemaBreadcrumb} lang={lang}>
  <!-- Cabecera de Categoría -->
  <header class="mb-10 pb-6 border-b border-brand-card-border/60">
    <nav class="flex items-center gap-2 text-xs text-brand-text-muted mb-4 font-semibold" aria-label="Ruta de navegación">
      <a href={`/${lang}`} class="hover:text-brand-text transition-colors">{lang === 'sv' ? 'Hem' : lang === 'it' ? 'Home' : 'Inicio'}</a>
      <span class="text-brand-card-border" aria-hidden="true">/</span>
      <span class="text-brand-text-muted">{lang === 'sv' ? 'Kategori' : lang === 'it' ? 'Categoria' : 'Categoría'}</span>
      <span class="text-brand-card-border" aria-hidden="true">/</span>
      <span class="text-brand-text">{localizedCatName}</span>
    </nav>

    <div class="flex items-center gap-3 mb-2">
      {cat.data.icon && <span class="text-3xl" aria-hidden="true">{cat.data.icon}</span>}
      <h1 class="text-3xl sm:text-4xl font-black text-brand-text font-['Outfit'] tracking-tight">
        {localizedCatName}
      </h1>
    </div>
    
    <p class="text-sm text-brand-text-muted max-w-2xl leading-relaxed">
      {cat.data.description}
    </p>
  </header>

  <!-- Listado de Herramientas -->
  {sortedTools.length > 0 ? (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {sortedTools.map(tool => (
        <ToolCard tool={tool} />
      ))}
    </div>
  ) : (
    <div class="text-center py-16 bg-brand-card-bg/10 border border-dashed border-brand-card-border rounded-2xl p-8">
      <div class="text-4xl mb-4" aria-hidden="true">⚙️</div>
      <h3 class="text-lg font-bold text-brand-text mb-2">
        {lang === 'sv' ? 'Fler verktyg kommer snart' : lang === 'it' ? 'Altri strumenti in arrivo' : 'Próximamente más herramientas'}
      </h3>
      <p class="text-sm text-brand-text-muted max-w-md mx-auto mb-6">
        {lang === 'sv' ? 'Vi granskar och skriver för närvarande fler säkra sidor för denna kategori.' : lang === 'it' ? 'Stiamo verificando e redigendo nuove schede sicure per questa categoria.' : 'Estamos verificando y redactando fichas seguras de descarga para esta categoría.'}
      </p>
      <a href={`/${lang}`} class="px-5 py-2.5 text-xs font-bold rounded-xl bg-brand-primary/10 text-brand-primary border border-brand-primary/20 hover:bg-brand-primary/20 transition-all inline-block">
        {t('category.back')}
      </a>
    </div>
  )}
</BaseLayout>
