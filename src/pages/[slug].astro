---
// src/pages/[slug].astro
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Badge from '../components/Badge.astro';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map(tool => ({
    params: { slug: tool.data.slug },
    props: { tool }
  }));
}

const { tool } = Astro.props;
const allTools = await getCollection('tools');
const toolsBySlug = new Map(allTools.map((entry) => [entry.data.slug, entry.data]));

const pricingLabels = {
  free: { label: 'Gratis', variant: 'success' as const },
  freemium: { label: 'Freemium', variant: 'primary' as const },
  paid: { label: 'De pago', variant: 'danger' as const },
  enterprise: { label: 'Enterprise', variant: 'neutral' as const },
  unknown: { label: 'Precio no confirmado', variant: 'neutral' as const }
};
const pricing = pricingLabels[tool.data.pricingModel] || pricingLabels.unknown;

const spanishSupportLabels = {
  yes: { label: 'Español disponible', variant: 'success' as const },
  partial: { label: 'Español parcial', variant: 'warning' as const },
  no: { label: 'Solo inglés', variant: 'danger' as const },
  unknown: { label: 'Idioma no confirmado', variant: 'neutral' as const }
};
const spanish = spanishSupportLabels[tool.data.spanishSupport] || spanishSupportLabels.unknown;

const trustLabels = {
  official: { label: 'Canal oficial', variant: 'success' as const },
  verified: { label: 'Enlace verificado', variant: 'secondary' as const },
  'pending-review': { label: 'Bajo revisión', variant: 'warning' as const }
};
const trust = trustLabels[tool.data.trustLevel] || { label: 'Pendiente', variant: 'neutral' as const };

const accountLabel = tool.data.requiresAccount === true
  ? 'Requiere cuenta'
  : tool.data.requiresAccount === false
    ? 'Sin cuenta obligatoria'
    : 'Cuenta no confirmada';

const formatReviewDate = (dateStr: string) => {
  try {
    return new Date(dateStr).toLocaleDateString('es-ES', {
      day: 'numeric',
      month: 'long',
      year: 'numeric'
    });
  } catch {
    return dateStr;
  }
};

const platformNames: Record<string, string> = {
  web: 'Web',
  windows: 'Windows',
  mac: 'macOS',
  linux: 'Linux',
  android: 'Android',
  ios: 'iOS'
};

const platformTypeLabels: Record<string, string> = {
  'official-site': 'Sitio oficial',
  'app-store': 'Tienda oficial',
  'web-app': 'Aplicación web',
  documentation: 'Documentación oficial',
  'official-installer': 'Instalador oficial',
  'github-repo': 'Repositorio oficial',
  'package-manager': 'Gestor de paquetes'
};

const platforms = Object.entries(tool.data.platforms)
  .filter(([, details]) => Boolean(details))
  .map(([platform, details]) => ({
    id: platform,
    name: platformNames[platform] ?? platform,
    details,
    typeLabel: platformTypeLabels[details!.type] ?? details!.type,
    host: new URL(details!.url).hostname.replace(/^www\./, '')
  }));

const primaryPlatform = platforms.find((item) => item.id === 'web') ?? platforms[0];
const primaryCta = primaryPlatform
  ? `/ir/${tool.data.slug}/${primaryPlatform.id}`
  : `/ir/${tool.data.slug}`;

let officialDomain = 'fuente oficial';
try {
  officialDomain = new URL(tool.data.officialWebsite).hostname.replace(/^www\./, '');
} catch {
  officialDomain = tool.data.officialWebsite;
}

const bestFor = tool.data.bestFor.length > 0
  ? tool.data.bestFor
  : tool.data.tags.slice(0, 4).map((tag: string) => `Usuarios que buscan ${tag.replaceAll('-', ' ')}`);

const editorialSummary = tool.data.editorialSummary ?? tool.data.longDescription;
const alternatives = tool.data.alternatives
  .map((slug: string) => toolsBySlug.get(slug))
  .filter(Boolean);

const visualAccents: Record<string, { bg: string; fg: string; border: string }> = {
  chatgpt: { bg: '#064e3b', fg: '#d1fae5', border: '#10b981' },
  claude: { bg: '#431407', fg: '#ffedd5', border: '#fb923c' },
  gemini: { bg: '#172554', fg: '#dbeafe', border: '#38bdf8' },
  cursor: { bg: '#082f49', fg: '#e0f2fe', border: '#38bdf8' },
  ollama: { bg: '#1c1917', fg: '#f5f5f4', border: '#d6d3d1' },
  'lm-studio': { bg: '#2e1065', fg: '#ede9fe', border: '#8b5cf6' },
  'stable-diffusion': { bg: '#4c0519', fg: '#ffe4e6', border: '#f43f5e' },
  midjourney: { bg: '#312e81', fg: '#e0e7ff', border: '#818cf8' },
  canva: { bg: '#164e63', fg: '#cffafe', border: '#22d3ee' },
  'microsoft-copilot': { bg: '#172554', fg: '#dbeafe', border: '#3b82f6' },
  perplexity: { bg: '#134e4a', fg: '#ccfbf1', border: '#2dd4bf' },
  anythingllm: { bg: '#365314', fg: '#ecfccb', border: '#a3e635' },
  jan: { bg: '#27272a', fg: '#f4f4f5', border: '#d4d4d8' },
  elevenlabs: { bg: '#831843', fg: '#fce7f3', border: '#f472b6' },
  runway: { bg: '#171717', fg: '#fafafa', border: '#d4d4d4' },
  'luma-dream-machine': { bg: '#3b0764', fg: '#f3e8ff', border: '#a855f7' },
  'github-copilot': { bg: '#0f172a', fg: '#e2e8f0', border: '#94a3b8' },
  deepl: { bg: '#172554', fg: '#dbeafe', border: '#60a5fa' },
  'gamma-app': { bg: '#701a75', fg: '#fae8ff', border: '#d946ef' },
  gemma: { bg: '#78350f', fg: '#fef3c7', border: '#fbbf24' },
  languagetool: { bg: '#064e3b', fg: '#d1fae5', border: '#34d399' },
  phind: { bg: '#164e63', fg: '#cffafe', border: '#22d3ee' },
  suno: { bg: '#713f12', fg: '#fef9c3', border: '#facc15' }
};
const visualAccent = visualAccents[tool.data.slug] ?? { bg: '#022c22', fg: '#ecfdf5', border: '#10b981' };
const toolInitials = tool.data.initials ?? tool.data.name
  .split(/\s+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((part: string) => part[0])
  .join('')
  .toUpperCase();
const generatedVisualSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="960" height="540" viewBox="0 0 960 540" role="img" aria-label="Identificador editorial de ${tool.data.name}"><rect width="960" height="540" rx="40" fill="${visualAccent.bg}"/><rect x="28" y="28" width="904" height="484" rx="30" fill="none" stroke="${visualAccent.border}" stroke-width="3" opacity=".55"/><circle cx="480" cy="250" r="112" fill="${visualAccent.border}" opacity=".12"/><text x="480" y="282" text-anchor="middle" font-family="Arial, sans-serif" font-size="96" font-weight="800" fill="${visualAccent.fg}">${toolInitials}</text><text x="480" y="360" text-anchor="middle" font-family="Arial, sans-serif" font-size="28" font-weight="700" fill="${visualAccent.fg}" opacity=".82">${tool.data.name} oficial</text></svg>`;
const generatedVisualUrl = `data:image/svg+xml,${encodeURIComponent(generatedVisualSvg)}`;
const toolImage = tool.data.screenshotUrl ?? generatedVisualUrl;

const schemaApp = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": tool.data.name,
  "description": tool.data.shortDescription,
  "applicationCategory": "OtherApplication",
  "applicationSubCategory": "Artificial Intelligence",
  "operatingSystem": platforms.map((platform) => platform.name).join(', '),
  "url": Astro.url.href,
  "dateModified": tool.data.lastReviewed,
  "image": toolImage,
  "sameAs": tool.data.officialSources,
  "offers": {
    "@type": "Offer",
    "price": tool.data.pricingModel === 'free' ? '0' : undefined,
    "priceCurrency": tool.data.pricingModel === 'free' ? 'USD' : undefined
  }
};

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": Astro.url.origin
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": tool.data.name,
      "item": Astro.url.href
    }
  ]
};

const schemaFaq = tool.data.faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": tool.data.faq.map((item: { question: string; answer: string }) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
} : null;

const jsonLd = schemaFaq ? [schemaApp, schemaBreadcrumb, schemaFaq] : [schemaApp, schemaBreadcrumb];
---

<BaseLayout
  title={`Dónde descargar ${tool.data.name} oficial y seguro | DescargasIA`}
  description={`Ficha editorial para encontrar los canales oficiales de ${tool.data.name}, revisar compatibilidad, advertencias de seguridad y alternativas similares.`}
  jsonLd={jsonLd}
>
  <nav class="mb-6 flex items-center gap-2 text-xs font-semibold text-brand-text-muted" aria-label="Ruta de navegación">
    <a href="/" class="hover:text-brand-text transition-colors">Inicio</a>
    <span class="text-brand-card-border" aria-hidden="true">/</span>
    <span class="text-brand-text">{tool.data.name}</span>
  </nav>

  <header class="relative overflow-hidden rounded-2xl border border-brand-card-border bg-brand-card-bg p-5 sm:p-7 lg:p-8">
    <div class="absolute inset-x-0 top-0 h-1 bg-brand-primary" aria-hidden="true"></div>
    <div class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
      <div>
        <div class="mb-4 flex flex-wrap gap-2">
          <Badge variant={trust.variant}>{trust.label}</Badge>
          <Badge variant={pricing.variant}>{pricing.label}</Badge>
          <Badge variant={spanish.variant}>{spanish.label}</Badge>
        </div>
        <h1 class="max-w-3xl text-4xl font-black leading-[1.02] tracking-tight text-brand-text font-['Outfit'] sm:text-5xl lg:text-6xl">
          Descargar {tool.data.name} oficial
        </h1>
        <p class="mt-4 max-w-2xl text-base leading-relaxed text-brand-text-muted sm:text-lg">
          {tool.data.shortDescription}
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a
            href={primaryCta}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-h-12 items-center justify-center rounded-lg border border-brand-primary bg-brand-primary px-5 py-3 text-sm font-black text-white transition-colors hover:bg-brand-primary-hover"
          >
            Ir a la descarga oficial
          </a>
          <a
            href="#compatibilidad"
            class="inline-flex min-h-12 items-center justify-center rounded-lg border border-brand-card-border bg-brand-bg/35 px-5 py-3 text-sm font-bold text-brand-text transition-colors hover:border-brand-primary/40 hover:text-brand-primary"
          >
            Ver plataformas
          </a>
        </div>
      </div>

      <aside class="overflow-hidden rounded-xl border border-brand-success-border bg-brand-success-bg" aria-label="Resumen de confianza">
        <img
          src={toolImage}
          alt={tool.data.screenshotUrl ? `Captura de pantalla oficial de ${tool.data.name}` : `Identificador visual editorial de ${tool.data.name}`}
          class="aspect-video w-full border-b border-brand-success-border object-cover"
          loading="eager"
        />
        <div class="p-4">
          <p class="text-[11px] font-black uppercase text-brand-success">Origen verificado</p>
          <p class="mt-2 font-mono text-lg font-black text-brand-text">{officialDomain}</p>
          <dl class="mt-4 grid grid-cols-2 gap-3 text-xs">
            <div class="rounded-lg border border-brand-card-border bg-brand-bg/35 p-3">
              <dt class="font-bold uppercase text-brand-text-muted">Plataformas</dt>
              <dd class="mt-1 font-black text-brand-text">{platforms.length}</dd>
            </div>
            <div class="rounded-lg border border-brand-card-border bg-brand-bg/35 p-3">
              <dt class="font-bold uppercase text-brand-text-muted">Cuenta</dt>
              <dd class="mt-1 font-black text-brand-text">{tool.data.requiresAccount === true ? 'Sí' : tool.data.requiresAccount === false ? 'No' : 'Por confirmar'}</dd>
            </div>
          </dl>
          <p class="mt-4 text-xs leading-relaxed text-brand-text-muted">
            Última revisión editorial: <strong class="text-brand-text">{formatReviewDate(tool.data.lastReviewed)}</strong>.
          </p>
        </div>
      </aside>
    </div>
  </header>

  <div class="mt-8 grid gap-8 lg:grid-cols-[1fr_22rem]">
    <main class="flex flex-col gap-8">
      <section class="rounded-2xl border border-brand-card-border bg-brand-card-bg/50 p-5" aria-labelledby="mejor-para-title">
        <h2 id="mejor-para-title" class="text-2xl font-black tracking-tight text-brand-text font-['Outfit']">
          Para qué es mejor {tool.data.name}
        </h2>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          {bestFor.map((item: string) => (
            <div class="rounded-xl border border-brand-card-border bg-brand-bg/35 p-4">
              <p class="text-sm font-bold leading-relaxed text-brand-text">{item}</p>
            </div>
          ))}
        </div>
      </section>

      <section id="compatibilidad" class="scroll-mt-20" aria-labelledby="descargas-title">
        <div class="mb-4 flex flex-col gap-1 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-[11px] font-black uppercase text-brand-primary">Canales oficiales</p>
            <h2 id="descargas-title" class="text-2xl font-black tracking-tight text-brand-text font-['Outfit']">
              Elige tu plataforma
            </h2>
          </div>
          <p class="text-xs text-brand-text-muted">No alojamos instaladores ni mirrors.</p>
        </div>

        <div class="grid gap-3">
          {platforms.map(({ id, name, details, typeLabel, host }) => (
            <article class="rounded-xl border border-brand-card-border bg-brand-card-bg p-4 transition-colors hover:border-brand-primary/35">
              <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <h3 class="text-lg font-black text-brand-text">{name}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-brand-text-muted">{details!.label}</p>
                  <div class="mt-3 flex flex-wrap gap-2 text-[10px] font-bold uppercase">
                    <span class="rounded border border-brand-card-border bg-brand-bg/35 px-2 py-1 text-brand-text-muted">{typeLabel}</span>
                    <span class="rounded border border-brand-success-border bg-brand-success-bg px-2 py-1 text-brand-success">{host}</span>
                    {details!.lastChecked && (
                      <span class="rounded border border-brand-card-border bg-brand-bg/35 px-2 py-1 text-brand-text-muted">
                        rev. {formatReviewDate(details!.lastChecked)}
                      </span>
                    )}
                  </div>
                </div>
                <a
                  href={`/ir/${tool.data.slug}/${id}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex min-h-11 shrink-0 items-center justify-center rounded-lg bg-brand-primary px-4 py-2 text-xs font-black text-white transition-colors hover:bg-brand-primary-hover"
                >
                  {details!.type === 'web-app' ? 'Abrir oficial' : 'Ir al canal oficial'}
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="rounded-2xl border border-brand-card-border bg-brand-card-bg/50 p-5" aria-labelledby="resumen-title">
        <h2 id="resumen-title" class="text-2xl font-black tracking-tight text-brand-text font-['Outfit']">
          Qué debes saber antes de usar {tool.data.name}
        </h2>
        <p class="mt-4 text-sm leading-7 text-brand-text-muted">{editorialSummary}</p>
      </section>

      {tool.data.editorialSections.length > 0 && (
        <section class="rounded-2xl border border-brand-card-border bg-brand-card-bg/50 p-5 sm:p-6" aria-labelledby="guia-title">
          <p class="text-[11px] font-black uppercase text-brand-primary">Guía editorial</p>
          <h2 id="guia-title" class="mt-1 text-2xl font-black tracking-tight text-brand-text font-['Outfit']">
            Guía completa para usar {tool.data.name} sin caer en descargas falsas
          </h2>
          <div class="mt-5 space-y-6">
            {tool.data.editorialSections.map((section: { heading: string; body: string }) => (
              <section class="border-t border-brand-card-border pt-5" aria-labelledby={`${tool.data.slug}-${section.heading.toLowerCase().replaceAll(' ', '-')}`}>
                <h3 id={`${tool.data.slug}-${section.heading.toLowerCase().replaceAll(' ', '-')}`} class="text-lg font-black tracking-tight text-brand-text font-['Outfit']">
                  {section.heading}
                </h3>
                <div class="mt-3 space-y-3 text-sm leading-7 text-brand-text-muted">
                  {section.body.split('\n\n').map((paragraph: string) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
              </section>
            ))}
          </div>
        </section>
      )}

      {tool.data.safetyNotes.length > 0 && (
        <section class="rounded-2xl border border-brand-warning-border bg-brand-warning-bg p-5" aria-labelledby="seguridad-title">
          <p class="text-[11px] font-black uppercase text-brand-warning-text">Seguridad</p>
          <h2 id="seguridad-title" class="mt-1 text-2xl font-black tracking-tight text-brand-text font-['Outfit']">
            Evita clones y descargas falsas
          </h2>
          <ul class="mt-4 grid gap-3 text-sm leading-relaxed text-brand-warning-text">
            {tool.data.safetyNotes.map((note: string) => (
              <li class="rounded-lg border border-brand-warning-border bg-brand-bg/20 p-3">{note}</li>
            ))}
          </ul>
        </section>
      )}

      {tool.data.limitations.length > 0 && (
        <section class="rounded-2xl border border-brand-card-border bg-brand-card-bg/50 p-5" aria-labelledby="limitaciones-title">
          <h2 id="limitaciones-title" class="text-2xl font-black tracking-tight text-brand-text font-['Outfit']">
            Limitaciones a tener en cuenta
          </h2>
          <ul class="mt-4 grid gap-3 text-sm leading-relaxed text-brand-text-muted">
            {tool.data.limitations.map((item: string) => (
              <li class="rounded-lg border border-brand-card-border bg-brand-bg/35 p-3">{item}</li>
            ))}
          </ul>
        </section>
      )}

      {tool.data.faq.length > 0 && (
        <section class="rounded-2xl border border-brand-card-border bg-brand-card-bg/50 p-5" aria-labelledby="faq-title">
          <h2 id="faq-title" class="text-2xl font-black tracking-tight text-brand-text font-['Outfit']">
            Preguntas frecuentes sobre {tool.data.name}
          </h2>
          <div class="mt-4 divide-y divide-brand-card-border">
            {tool.data.faq.map((item: { question: string; answer: string }) => (
              <details class="group py-4">
                <summary class="cursor-pointer list-none text-sm font-black text-brand-text">
                  {item.question}
                </summary>
                <p class="mt-3 text-sm leading-7 text-brand-text-muted">{item.answer}</p>
              </details>
            ))}
          </div>
        </section>
      )}
    </main>

    <aside class="flex flex-col gap-6">
      <section class="rounded-2xl border border-brand-card-border bg-brand-card-bg p-5" aria-labelledby="ficha-title">
        <h2 id="ficha-title" class="text-lg font-black text-brand-text font-['Outfit']">Ficha rápida</h2>
        <dl class="mt-4 grid gap-3 text-sm">
          <div class="flex items-center justify-between gap-3 border-b border-brand-card-border pb-3">
            <dt class="text-brand-text-muted">Precio</dt>
            <dd class="font-bold text-brand-text">{pricing.label}</dd>
          </div>
          <div class="flex items-center justify-between gap-3 border-b border-brand-card-border pb-3">
            <dt class="text-brand-text-muted">Cuenta</dt>
            <dd class="font-bold text-brand-text">{accountLabel}</dd>
          </div>
          <div class="flex items-center justify-between gap-3 border-b border-brand-card-border pb-3">
            <dt class="text-brand-text-muted">Español</dt>
            <dd class="font-bold text-brand-text">{spanish.label}</dd>
          </div>
          <div class="flex items-center justify-between gap-3">
            <dt class="text-brand-text-muted">Confianza</dt>
            <dd class="font-bold text-brand-text">{trust.label}</dd>
          </div>
        </dl>
      </section>

      {alternatives.length > 0 && (
        <section class="rounded-2xl border border-brand-card-border bg-brand-card-bg p-5" aria-labelledby="alternativas-title">
          <h2 id="alternativas-title" class="text-lg font-black text-brand-text font-['Outfit']">
            Alternativas similares
          </h2>
          <div class="mt-4 grid gap-2">
            {alternatives.map((alt: any) => (
              <a
                href={`/${alt.slug}`}
                class="rounded-xl border border-brand-card-border bg-brand-bg/35 p-3 transition-colors hover:border-brand-primary/35"
              >
                <span class="block text-sm font-black text-brand-text">{alt.name}</span>
                <span class="mt-1 block text-xs leading-relaxed text-brand-text-muted">{alt.shortDescription}</span>
              </a>
            ))}
          </div>
        </section>
      )}

      {tool.data.officialSources.length > 0 && (
        <section class="rounded-2xl border border-brand-card-border bg-brand-card-bg p-5" aria-labelledby="fuentes-title">
          <h2 id="fuentes-title" class="text-lg font-black text-brand-text font-['Outfit']">Fuentes oficiales</h2>
          <div class="mt-4 grid gap-2">
            {tool.data.officialSources.map((source: string) => (
              <a href={source} target="_blank" rel="noopener noreferrer" class="truncate rounded-lg border border-brand-card-border bg-brand-bg/35 px-3 py-2 font-mono text-xs font-bold text-brand-primary hover:underline">
                {new URL(source).hostname.replace(/^www\./, '')}
              </a>
            ))}
          </div>
        </section>
      )}
    </aside>
  </div>
</BaseLayout>
